# Service identity and runtime basics.
APP_NAME=termai-rerank
APP_ENV=prod
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080

# Startup behavior:
# - best_effort: start even if some models fail.
# - strict: fail startup if a required model cannot load.
STARTUP_MODE=best_effort

# Default model used when request omits model_name.
DEFAULT_MODEL_NAME=msmarco

# Comma-separated logical model names to initialize at startup.
ENABLED_MODELS=msmarco,bge

# Model registry definition (JSON object):
# key = logical model name, type = adapter family, identifier = model id/path.
MODEL_DEFINITIONS={"msmarco":{"type":"msmarco","identifier":"cross-encoder/ms-marco-MiniLM-L-6-v2","required":true},"bge":{"type":"bge","identifier":"BAAI/bge-reranker-base","required":true}}

# Optional per-family identifier overrides.
# If set, these values override MODEL_DEFINITIONS identifiers.
MSMARCO_MODEL_IDENTIFIER=
BGE_MODEL_IDENTIFIER=

# Inference runtime controls.
DEVICE=cpu
INFERENCE_TIMEOUT_SECONDS=15
USE_MOCK_INFERENCE=true

# Request safety limits.
MAX_CANDIDATES_PER_REQUEST=100
MAX_QUERY_LENGTH=2048
MAX_CANDIDATE_TEXT_LENGTH=5000
MAX_METADATA_BYTES=16384

# Observability toggles.
METRICS_ENABLED=true
EXPOSE_METRICS_ENDPOINT=true
